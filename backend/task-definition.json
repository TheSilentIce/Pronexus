{
  "family": "pronexus-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::539994123701:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "pronexus-backend",
      "image": "539994123701.dkr.ecr.us-east-1.amazonaws.com/pronexus-backend:latest",
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "CLAUDE",
          "value": "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"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/pronexus-backend",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
